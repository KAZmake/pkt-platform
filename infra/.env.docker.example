# Скопируй в .env.docker и задай реальные значения
# Порты: PostgreSQL=5433, Valkey=6380 (смещены чтобы не конфликтовать с другими проектами)
POSTGRES_USER=pkt
POSTGRES_PASSWORD=change_me
POSTGRES_DB=pkt_db

KEYCLOAK_DB_USER=keycloak
KEYCLOAK_DB_PASSWORD=change_me

KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=change_me

MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change_me

DIRECTUS_SECRET=change_me_long_random_string
DIRECTUS_DB_USER=directus
DIRECTUS_DB_PASSWORD=change_me
DIRECTUS_ADMIN_EMAIL=admin@pkt.kz
DIRECTUS_ADMIN_PASSWORD=change_me
# Keycloak client secret для Directus OIDC (берётся из Keycloak Admin → Clients → directus → Credentials)
DIRECTUS_KEYCLOAK_SECRET=change_me
# UUID роли Directus по умолчанию для новых SSO пользователей (берётся из Directus → Settings → Roles)
DIRECTUS_DEFAULT_ROLE_ID=change_me
